# ── Core ─────────────────────────────────────────────────────
CLAUDE_API_KEY=           # Anthropic — required, server won't start without it
OPENWEATHER_API_KEY=      # OpenWeatherMap
OPENWEATHER_CITY=Pune
PORCUPINE_ACCESS_KEY=     # Wake word detection
PORT=3000
NODE_ENV=production

# ── Spotify ──────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Google (Calendar, Gmail, YouTube) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── News ─────────────────────────────────────────────────────
NEWSAPI_KEY=

# ── Fitness ──────────────────────────────────────────────────
EXERCISEDB_API_KEY=

# ── YouTube ──────────────────────────────────────────────────
YOUTUBE_API_KEY=          # Optional — falls back to Google OAuth

# ── Morning Briefing Auto-Trigger ────────────────────────────

# Cron schedule for fixed-time briefing
# Default: 7:00 AM IST every day
BRIEFING_CRON=0 7 * * *

# Enable/disable PIR motion auto-trigger
# Set to 'false' to disable PIR triggering
# Default: true
BRIEFING_PIR_TRIGGER=true

# Morning window — briefing only fires if PIR motion detected in this window
# Window: BRIEFING_WINDOW_START:00 to BRIEFING_WINDOW_END:BRIEFING_WINDOW_END_MIN
# Default: 6:00 AM to 9:30 AM IST
BRIEFING_WINDOW_START=6
BRIEFING_WINDOW_END=9
BRIEFING_WINDOW_END_MIN=30

# Cooldown in hours after a briefing fires
# Prevents re-triggering if you leave/re-enter room
# Default: 2 hours
BRIEFING_COOLDOWN_HOURS=2

# Delay in milliseconds between PIR detection and briefing starting
# Gives person time to stand in front of mirror
# Default: 3000 (3 seconds)
BRIEFING_PIR_DELAY_MS=3000
